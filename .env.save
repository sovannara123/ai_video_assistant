# .env
OLLAMA_MODEL=llama3
EMBEDDING_MODEL=all-MiniLM-L6-v2
OLLAMA_BASE_URL=http://localhost:11434
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_RESULTS=5




# ── HUMAN-LIKE AI SETTINGS ────────────────────
TEMPERATURE=0.7          # 0.5=more factual / 1.0=more creative
TOP_P=0.9                # 0.7=narrower focus / 0.95=more variety
REPETITION_PENALTY=1.1   # 1.0=no effect / 1.2=less repetition
FREQUENCY_PENALTY=0.3    # 0.5=stronger penalty on repeated words
PRESENCE_PENALTY=0.4     # 0.5=encourages discussing new topics
MAX_OUTPUT_TOKENS=800    #
